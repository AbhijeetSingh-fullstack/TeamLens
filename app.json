{
  "expo": {
    "name": "TeamLens",
    "slug": "teamlens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/TeamLens.png",
    "scheme": "teamlens",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/TeamLens.png"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/TeamLens.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.abhijeetsingh200.teamlens"
    },
    "androidStatusBar": {
      "translucent": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/TeamLens.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/TeamLens.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/TeamLens.png",
            "imageWidth": 200
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dd7ed27c-6c86-448d-86c6-d67641d80594"
      }
    },
    "owner": "abhijeetsingh200"
  }
}
